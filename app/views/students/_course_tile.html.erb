<div class="row">
  <div class="col-md-12 col-xs-12 <%= 'mobile-class' if browser.device.mobile? %>" tooltip="<%= "#{course.description} - Recommended Grades: #{course.suggested_grade}" %>">
    <span class="course-name">
      <%= course.name %> <span class="small-text">
        <%= "- One-Time Course Fee: #{number_to_currency(course.fee, unit: '$', precision: 0)}" if course.fee > 0 %>
      </span>
    </span>
  </div>
</div>
